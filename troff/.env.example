# App
APP_TIMEZONE=America/Los_Angeles
DATABASE_URL=sqlite:///./data/troff.db
DAILY_DISPATCH_LOCAL_TIME=09:00
ENABLE_SCHEDULER=false
ENABLED_SURFACES=blog,linkedin,reddit
BLOG_OUTBOX_DIR=./data/outbox/blog
BLOG_GOOD_THRESHOLD=75
MAX_RETRIES=3

# Optional AI generation (fallback templates are used if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
BLOG_WORD_COUNT=1500
BLOG_DEFAULT_AUDIENCE="operators, founders, and clinicians who run a practice"
BLOG_DEFAULT_POV="first-person plural we or first-person singular I, whichever reads more natural"

# Postiz API (required for LinkedIn/Facebook/Instagram/TikTok)
# Hosted default. Supports either:
# - https://api.postiz.com
# - https://api.postiz.com/public/v1
POSTIZ_API_KEY=
POSTIZ_API_URL=https://api.postiz.com
POSTIZ_INTEGRATION_LINKEDIN=
POSTIZ_INTEGRATION_REDDIT=
POSTIZ_INTEGRATION_FACEBOOK=
POSTIZ_INTEGRATION_INSTAGRAM=
POSTIZ_INTEGRATION_TIKTOK=

# Landing publishing (preferred)
LANDING_REPO_PATH=
LANDING_BASE_URL=https://www.billwithbomi.com
PR_BRANCH_PREFIX=codex/troff-blog
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Reddit defaults (publishing goes through Postiz in MVP)
REDDIT_DEFAULT_SUBREDDIT=billwithbomi

# Media generation/storage
ENABLE_MEDIA_CARDS=false
MEDIA_CARD_SURFACES=linkedin,facebook,instagram,tiktok
MEDIA_PROVIDER=gcs
GCS_BUCKET=
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-key.json
PUBLIC_MEDIA_BASE_URL=
MEDIA_CARD_OUTPUT_DIR=app/static/generated/cards
CARD_BG_HEX=#0F172A
CARD_FG_HEX=#F8FAFC
CARD_WIDTH=1080
CARD_HEIGHT=1080
