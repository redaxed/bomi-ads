# Google Ads API credentials.
#
# Copy this file to `.env` and fill in local values:
#
#   cp .env.example .env
#
# Never commit `.env`.

# Developer token from the Google Ads manager account API Center.
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth client credentials from Google Cloud Console.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# OAuth refresh token generated for scope:
# https://www.googleapis.com/auth/adwords
GOOGLE_ADS_REFRESH_TOKEN=

# Advertiser/customer account that owns the campaigns.
GOOGLE_ADS_CUSTOMER_ID=

# Manager/MCC account used as the API login customer.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional. Defaults to v24 in the script.
GOOGLE_ADS_API_VERSION=v24
